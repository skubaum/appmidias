<!-- image-modal.xml -->
<Page xmlns="http://schemas.nativescript.org/tns.xsd" xmlns:VideoPlayer="nativescript-videoplayer" shownModally="onShownModally">
  <GridLayout rows="auto, *" columns="*" backgroundColor="black">
    <GridLayout row="0" columns="*, auto" padding="10" backgroundColor="#80000000">
        <Label col="0" text="{{ nome }}" textWrap="true" color="white" verticalAlignment="center" />
        <Button col="1" text="X" tap="onClose" width="40" height="40" color="white" backgroundColor="transparent" fontSize="20" fontWeight="bold" />
    </GridLayout>

    <GridLayout row="1">
        <Image src="{{ imageUrl }}" stretch="aspectFit" visibility="{{ imageUrl ? 'visible' : 'collapsed' }}" />
        <VideoPlayer:Video
            src="{{ videoUrl }}"
            stretch="aspectFit"
            loaded="videoplayerLoaded" 
            finished="videoFinished" 
            autoplay="true"
            visibility="{{ videoUrl ? 'visible' : 'collapsed' }}" />
    </GridLayout>
  </GridLayout>
</Page>
