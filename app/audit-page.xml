<Page xmlns="http://schemas.nativescript.org/tns.xsd" navigatingTo="onNavigatingTo">
    <ActionBar title="Auditoria" class="action-bar">
        <NavigationButton text="Voltar" android.systemIcon="ic_menu_back" tap="onGoBack"/>
        <ActionItem tap="onClearLogs" android.systemIcon="ic_menu_delete" android.position="right" />
    </ActionBar>

    <GridLayout rows="*">
        <!-- Display logs inside a ListView -->
        <ListView items="{{ logs }}" class="list-group">
            <ListView.itemTemplate>
                <StackLayout class="list-group-item" padding="10">
                    <Label text="{{ timestamp }}" class="text-primary" fontWeight="bold" fontSize="12" />
                    <Label text="{{ message }}" textWrap="true" fontSize="14" marginTop="4" />
                </StackLayout>
            </ListView.itemTemplate>
        </ListView>
        
        <!-- Show this if there are no logs -->
        <Label text="Nenhum registro de auditoria encontrado."
               visibility="{{ logs.length === 0 ? 'visible' : 'collapsed' }}"
               horizontalAlignment="center" verticalAlignment="center"
               textWrap="true" class="h3 text-muted" />
    </GridLayout>
</Page>
